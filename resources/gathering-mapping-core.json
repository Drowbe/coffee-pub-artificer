{
  "version": 3,
  "notes": "Gathering art mapping. Structure: biomes[biome][state (idle|active)][anyFamily | byFamily[family]]. familyAliases maps Artificer family names (lowercased) to byFamily bucket keys. The 'any' biome is the universal fallback when no explicit biome entry matches.",

  "runtimeDefaults": {
    "notes": "Optional overrides for gather pin behavior, discovery, and Blacksmith sound ids (basename, no .mp3). Omitted keys use module builtins.",
    "pinAnimationTimeoutMs": 5000,
    "discoveryMinPointSeparationPx": 90,
    "pinDefaultImage": "fa-solid fa-seedling",
    "pinSize": 100,
    "soundExploreSuccess": "interface-notification-10",
    "soundExploreFail": "interface-error-03",
    "soundPopulate": "fanfare-success-2",
    "soundClear": "interface-button-10",
    "discoveryRadiusUnits": 60,
    "discoveryRarityOffsets": {
      "common": 0,
      "uncommon": 3,
      "rare": 6,
      "very rare": 10,
      "legendary": 14
    },
    "pinDesign": {
      "notes": "When overrideDefaultPinDesign is true, these values replace the Blacksmith registered design. When false, the registered design wins and these are ignored. shape options: 'circle', 'square', 'none' (icon only, no background). textLayout options: 'under' (below pin), 'over' (centered over pin), 'above' (above pin), 'right' (right of pin), 'left' (left of pin), 'arc-above' (curved above), 'arc-below' (curved below). textDisplay options: 'always', 'hover', 'never', 'gm' (GM only).",
      "overrideDefaultPinDesign": true,
      "shape": "none",
      "dropShadow": true,
      "imageFit": "contain",
      "imageZoom": 1,
      "textLayout": "arc-below",
      "textDisplay": "hover",
      "textColor": "#ffffff",
      "textSize": 12,
      "textMaxLength": 0,
      "textMaxWidth": 0,
      "textScaleWithPin": true,
      "fill": "#0f0f0f",
      "stroke": "#ffffff",
      "strokeWidth": 3,
      "iconColor": "#eaffe5"
    }
  },

  "familyAliases": {
    "plant": "plant",
    "plants": "plant",
    "environmental": "environmental",
    "essence": "essence",
    "gem": "gem",
    "gems": "gem",
    "mineral": "mineral",
    "minerals": "mineral",
    "ore": "mineral",
    "rocks": "mineral",
    "rock": "mineral",
    "creaturepart": "creature parts",
    "creatureparts": "creature parts",
    "creature_parts": "creature parts",
    "creature": "creature parts"
  },

